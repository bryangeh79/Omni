# Omni Ai Chatbot — Environment Variables Example
# Copy to .env and fill in real values. NEVER commit .env.

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_SECRET=REPLACE_WITH_RANDOM_32_CHAR_SECRET

# ── Ports ────────────────────────────────────────────────────────────────────
PORT_WEB=43110
PORT_API=43111
PORT_WORKER=43112
PORT_POSTGRES=43113
PORT_REDIS=43114

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
DATABASE_URL=postgresql://omni_user:REPLACE_PASSWORD@localhost:43113/omni_dev

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:43114

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=REPLACE_WITH_RANDOM_64_CHAR_SECRET
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=REPLACE_WITH_OPENAI_KEY
OPENAI_MODEL=gpt-4o

# ── Meta WhatsApp Business API (Phase 5) ────────────────────────────────────
META_PHONE_NUMBER_ID=REPLACE
META_WHATSAPP_TOKEN=REPLACE
META_WEBHOOK_VERIFY_TOKEN=REPLACE

# ── WhatsApp Web sessions ────────────────────────────────────────────────────
# Stored locally; path must be inside C:\AI_WORKSPACE\Omni Ai Chatbot
WHATSAPP_WEB_SESSION_DIR=./data/wa-sessions

# ── AI Key Vault ─────────────────────────────────────────────────────────────
# 32-byte random secret for AES-256-GCM tenant API key encryption.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# NEVER commit a real value. NEVER share between environments.
OMNI_API_KEY_ENCRYPTION_SECRET=REPLACE_WITH_64_CHAR_HEX_RANDOM_SECRET

# ── Optional real provider smoke tests ───────────────────────────────────────
# Set to true ONLY when a real tenant API key is stored and you want the smoke
# test to make real provider calls. Default is false (no external API calls).
OMNI_ENABLE_REAL_OPENAI_SMOKE=false
OMNI_ENABLE_REAL_GEMINI_SMOKE=false
OMNI_ENABLE_REAL_DEEPSEEK_SMOKE=false

# ── Meta WhatsApp Business Platform ──────────────────────────────────────────
# Enable real Meta API message sends. Default: disabled (stub mode).
# Set to true ONLY with a valid Meta access token configured on the channel.
# NEVER enable in default/smoke test environments.
OMNI_ENABLE_REAL_META_SEND=false

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
