// Omni Ai Chatbot — Database Schema Draft
// Phase 0: draft only. Migrations applied in Phase 1.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// TENANT & AUTH
// ─────────────────────────────────────────────────────────────────────────────

model Tenant {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  defaultLanguage String   @default("zh") // zh | en | ms
  plan            String   @default("trial")
  isActive        Boolean  @default(true)
  // Round-9B: SaaS Admin tenant provisioning + license/contract foundation.
  // serviceStatus: TRIAL | ACTIVE | PAST_DUE | SUSPENDED | EXPIRED | CANCELLED
  serviceStatus    String    @default("TRIAL")
  contractStartAt  DateTime?
  contractEndAt    DateTime?
  licenseCode      String?   @unique
  suspensionReason String?
  internalNotes    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users             User[]
  channels          Channel[]
  customers         Customer[]
  conversations     Conversation[]
  knowledgeItems    KnowledgeItem[]
  aiConfig          AiConfig?
  followUpRules     FollowUpRule[]
  followUpTasks     FollowUpTask[]
  handoffRules      HandoffRule[]
  onboardingDraft   OnboardingDraft?
  channelSetupDraft ChannelSetupDraft?
  billingState      TenantBillingState?
}

// ─────────────────────────────────────────────────────────────────────────────
// Round-9A: COMMERCIAL FOUNDATION
// Single per-tenant row holding quota counters, add-ons, credits, AI smart-reply
// toggle, and a stub purchase ledger. No real payment gateway. Auditable.
// ─────────────────────────────────────────────────────────────────────────────

model TenantBillingState {
  id                    String   @id @default(cuid())
  tenantId              String   @unique
  // AI Smart Reply default ON for Starter and Pro. Tenant can toggle.
  aiSmartReplyEnabled   Boolean  @default(true)
  // Tracks the "year-month" string e.g. "2026-05" the monthlyUsage row applies to.
  // Used to auto-reset monthly counters on month rollover.
  currentMonthKey       String   @default("")
  // monthlyUsage = { faqGenerations: int, aiReplies: int }
  monthlyUsage          Json     @default("{\"faqGenerations\":0,\"aiReplies\":0}")
  // addOnsActive = [{ id, kind, slots?|credits?, priceRm, purchasedAt, expiresAt?, recurring? }, ...]
  addOnsActive          Json     @default("[]")
  // purchasedCredits = { faq: int, aiReply: int } — non-expired one-time credit balance
  purchasedCredits      Json     @default("{\"faq\":0,\"aiReply\":0}")
  // ledger = [{ id, eventType, status, externalEventId?, payload, beforeBalance, afterBalance, at }, ...]
  // Append-only stub. No real payment provider keys/tokens are ever stored.
  ledger                Json     @default("[]")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  tenant                Tenant   @relation(fields: [tenantId], references: [id])
}

model User {
  id           String   @id @default(cuid())
  tenantId     String
  email        String
  passwordHash String
  name         String
  role         UserRole @default(AGENT)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant       Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, email])
}

enum UserRole {
  OWNER
  ADMIN
  MANAGER
  AGENT
  VIEWER
}

// ─────────────────────────────────────────────────────────────────────────────
// CHANNEL
// ─────────────────────────────────────────────────────────────────────────────

model Channel {
  id           String      @id @default(cuid())
  tenantId     String
  type         ChannelType
  displayName  String
  isActive     Boolean     @default(true)
  // WhatsApp Web: session reference (not session content)
  waWebSessionRef String?
  // Meta WhatsApp Business Platform API fields
  metaPhoneNumberId         String?    // numeric phone number ID from Meta
  wabaId                    String?    // WhatsApp Business Account ID
  displayPhoneNumber        String?    // human-readable display number
  metaAccessTokenRef        String?    // AES-256-GCM encrypted Meta access token
  metaAccessTokenLast4      String?    // last 4 chars (display only, never raw)
  metaAccessTokenUpdatedAt  DateTime?
  webhookVerifyTokenRef     String?    // AES-256-GCM encrypted webhook verify token
  metaAppSecretRef          String?    // AES-256-GCM encrypted Meta app secret (for HMAC verification)
  metaAppSecretLast4        String?    // last 4 chars (display only)
  metaAppSecretUpdatedAt    DateTime?
  lastWebhookAt             DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  tenant       Tenant      @relation(fields: [tenantId], references: [id])
  conversations Conversation[]
}

enum ChannelType {
  WHATSAPP_WEB
  META_API
  FACEBOOK_MESSENGER
  INSTAGRAM
  WECHAT
  ZALO
  LINE
  TIKTOK
}

// ─────────────────────────────────────────────────────────────────────────────
// CRM — CUSTOMER
// ─────────────────────────────────────────────────────────────────────────────

model Customer {
  id                  String       @id @default(cuid())
  tenantId            String
  phone               String
  whatsappName        String?
  name                String?
  company             String?
  industry            String?
  region              String?
  languagePreference  String?      // zh | en | ms
  source              String?
  interestedProduct   String?
  need                String?
  budget              String?
  purchaseTiming      String?
  urgency             Int?         // 1-5
  painPoint           String?
  stage               LeadStage    @default(NEW)
  score               Int          @default(0)
  ownerId             String?
  nextFollowUpAt      DateTime?
  notes               String?
  isBlacklisted       Boolean      @default(false)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  tenant              Tenant       @relation(fields: [tenantId], references: [id])
  tags                CustomerTag[]
  conversations       Conversation[]
  followUpTasks       FollowUpTask[]

  @@unique([tenantId, phone])
}

enum LeadStage {
  NEW
  INTERESTED
  HIGH_INTENT
  QUOTED
  BOOKED
  WON
  LOST
  AFTER_SALES
}

model CustomerTag {
  id         String   @id @default(cuid())
  customerId String
  tag        String
  createdAt  DateTime @default(now())

  customer   Customer @relation(fields: [customerId], references: [id])

  @@unique([customerId, tag])
}

// ─────────────────────────────────────────────────────────────────────────────
// CONVERSATION & MESSAGE
// ─────────────────────────────────────────────────────────────────────────────

model Conversation {
  id              String             @id @default(cuid())
  tenantId        String
  channelId       String
  customerId      String
  status          ConversationStatus @default(AI_HANDLING)
  assignedUserId  String?
  lastMessageAt   DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  tenant          Tenant             @relation(fields: [tenantId], references: [id])
  channel         Channel            @relation(fields: [channelId], references: [id])
  customer        Customer           @relation(fields: [customerId], references: [id])
  messages        Message[]
  followUpTasks   FollowUpTask[]
}

enum ConversationStatus {
  AI_HANDLING
  HUMAN_HANDLING
  PENDING_HANDOFF
  CLOSED
}

model Message {
  id               String      @id @default(cuid())
  conversationId   String
  direction        Direction
  senderType       SenderType
  content          String
  detectedLanguage String?     // zh | en | ms
  channelMessageId String?
  isRead           Boolean     @default(false)
  createdAt        DateTime    @default(now())

  conversation     Conversation @relation(fields: [conversationId], references: [id])
}

enum Direction {
  INBOUND
  OUTBOUND
}

enum SenderType {
  CUSTOMER
  AI
  HUMAN_AGENT
  SYSTEM
}

// ─────────────────────────────────────────────────────────────────────────────
// KNOWLEDGE BASE
// ─────────────────────────────────────────────────────────────────────────────

model KnowledgeItem {
  id        String            @id @default(cuid())
  tenantId  String
  type      KnowledgeItemType
  question  String?
  answer    String
  language  String            @default("zh")
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  tenant    Tenant            @relation(fields: [tenantId], references: [id])
}

enum KnowledgeItemType {
  GLOBAL_FAQ
  PRODUCT_FAQ
  KNOWLEDGE_CHUNK
}

// ─────────────────────────────────────────────────────────────────────────────
// AI CONFIG
// ─────────────────────────────────────────────────────────────────────────────

model AiConfig {
  id                  String   @id @default(cuid())
  tenantId            String   @unique
  aiProvider          String   @default("DRY_RUN")   // OPENAI | GEMINI | DEEPSEEK | PLATFORM_DEFAULT | DRY_RUN
  model               String   @default("dry-run")
  useTenantApiKey     Boolean  @default(false)
  apiKeyRef           String?  // AES-256-GCM encrypted key blob (base64) — never store raw
  apiKeyLast4         String?  // last 4 chars of original key (for display only)
  apiKeyProvider      String?  // OPENAI | GEMINI | DEEPSEEK — which provider the key is for
  apiKeyUpdatedAt     DateTime?
  persona             String?
  goals               String[] // array of goal keys
  systemPrompt        String?
  replyLanguagePolicy String   @default("AUTO")       // AUTO | zh | en | ms
  temperature         Float?
  maxTokens           Int?
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant              Tenant   @relation(fields: [tenantId], references: [id])
}

// ─────────────────────────────────────────────────────────────────────────────
// AUTOMATION RULES
// ─────────────────────────────────────────────────────────────────────────────

// ─────────────────────────────────────────────────────────────────────────────
// FOLLOW-UP TASKS (runtime instances, Phase 9B)
// ─────────────────────────────────────────────────────────────────────────────

model FollowUpTask {
  id               String         @id @default(cuid())
  tenantId         String
  conversationId   String
  customerId       String
  ruleId           String?        // optional ref to source FollowUpRule (config)
  scenario         String         // trigger key: PRICE_ASKED_NO_REPLY | CONSIDERING | etc.
  stepIndex        Int            @default(0)  // 0=first, 1=second follow-up in the chain
  dueAt            DateTime
  status           FollowUpStatus @default(PENDING)
  requiresHuman    Boolean        @default(false)  // true = human/admin reminder, not customer auto-send
  suggestedMessage String?        // deterministic template message (not AI-generated in Phase 9B)
  completedAt      DateTime?
  cancelledAt      DateTime?
  cancelledReason  String?        // CUSTOMER_REPLIED | MANUAL | CONVERSATION_CLOSED
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  tenant           Tenant         @relation(fields: [tenantId], references: [id])
  conversation     Conversation   @relation(fields: [conversationId], references: [id])
  customer         Customer       @relation(fields: [customerId], references: [id])

  @@index([tenantId, status, dueAt])
  @@index([conversationId, status])
}

enum FollowUpStatus {
  PENDING
  DONE
  CANCELLED
  SKIPPED
}

// ─────────────────────────────────────────────────────────────────────────────

model FollowUpRule {
  id           String   @id @default(cuid())
  tenantId     String
  trigger      String   // e.g. PRICE_ASKED_NO_REPLY, CONSIDERING, HIGH_INTENT_UNHANDLED
  delayHours   Int
  messageTemplate String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  tenant       Tenant   @relation(fields: [tenantId], references: [id])
}

model HandoffRule {
  id        String   @id @default(cuid())
  tenantId  String
  condition String   // e.g. USER_REQUESTS_HUMAN, SCORE_GTE_80, FAQ_NO_ANSWER
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  tenant    Tenant   @relation(fields: [tenantId], references: [id])
}

// ─────────────────────────────────────────────────────────────────────────────
// ONBOARDING WIZARD (Phase 11B)
// ─────────────────────────────────────────────────────────────────────────────

model OnboardingDraft {
  id               String   @id @default(cuid())
  tenantId         String   @unique  // one draft per tenant
  status           OnboardingStatus @default(DRAFT)

  // Step 1: Company basics
  companyName      String?
  industry         String?
  whatsappNumber   String?
  website          String?
  serviceArea      String?
  businessHours    String?  // JSON-serialised or plain text

  // Step 2: AI goals (stored as string array)
  aiGoals          String[]

  // Step 3: Materials input
  materialsText    String?  // pasted product/service text
  materialsUrl     String?  // reference URL placeholder

  // Step 4+: Generated preview (deterministic stub — no real AI provider)
  generatedPreview Json?    // persona, welcomeMsg, faqCategories, leadStages, etc.

  // Activation metadata
  enabledAt        DateTime?
  completedSteps   Int      @default(0)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant           Tenant   @relation(fields: [tenantId], references: [id])
}

enum OnboardingStatus {
  DRAFT
  PREVIEWED
  ENABLED
}

// ─────────────────────────────────────────────────────────────────────────────
// CHANNEL SETUP DRAFT (Phase 13A)
// ─────────────────────────────────────────────────────────────────────────────

model ChannelSetupDraft {
  id               String              @id @default(cuid())
  tenantId         String              @unique          // one draft per tenant
  channelType      String?                              // WA_WEB | META_WA_BUSINESS
  displayName      String?
  phoneLast4       String?                              // last 4 digits only — never store full phone
  setupStatus      ChannelSetupStatus  @default(DRAFT)
  credentialStatus CredentialStatus    @default(NONE)
  credentialRef    String?                              // AES-256-GCM encrypted JSON blob — never plaintext
  credentialLast4  String?                              // last 4 chars of access token for display only
  testStatus       String              @default("NOT_TESTED")
  lastTestAt       DateTime?
  realWaSessionEnabled Boolean         @default(false)  // safety flag snapshot — always false by default
  realMetaSendEnabled  Boolean         @default(false)  // safety flag snapshot — always false by default
  activationNotes  String?
  // Round-9D: tenant-driven activation request lifecycle.
  // Values: NOT_STARTED | READY_TO_REQUEST | REQUESTED | APPROVED_BY_SAAS_ADMIN | BLOCKED | LIVE
  activationStatus      String?
  activationRequestedAt DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  tenant           Tenant              @relation(fields: [tenantId], references: [id])
}

enum ChannelSetupStatus {
  DRAFT
  TESTED_STUB
  READY_FOR_CREDENTIALS
  CREDENTIALS_SAVED
  ACTIVATION_PENDING
  ACTIVE
  FAILED
}

enum CredentialStatus {
  NONE
  DRAFT
  ENCRYPTED_STORED
}

// ─────────────────────────────────────────────────────────────────────────────
// AUDIT LOG (Phase 15C)
// ─────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id           String   @id @default(cuid())
  tenantId     String
  actorUserId  String?
  actorRole    String?
  action       String
  entityType   String
  entityId     String?
  metadataJson String   @default("{}")
  ip           String?
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, action])
}

// ─────────────────────────────────────────────────────────────────────────────
// USAGE METERING
// ─────────────────────────────────────────────────────────────────────────────

model UsageRecord {
  id          String   @id @default(cuid())
  tenantId    String
  date        DateTime @db.Date
  llmTokens   Int      @default(0)
  llmCostUsd  Float    @default(0)
  messages    Int      @default(0)
  createdAt   DateTime @default(now())

  @@unique([tenantId, date])
}
